# ── Wazuh SIEM Integration ─────────────────────────────────────────────────────
# Wazuh Manager REST API base URL.
# When Gateway runs in Docker on the same EC2 host as Wazuh, use host.docker.internal
# (the docker-compose.yml already adds the required extra_hosts entry for Linux Docker).
WAZUH_URL=https://host.docker.internal:55000

# Wazuh API credentials.
# Create a dedicated API user in Wazuh: Wazuh Dashboard → Security → Users → Create user
# Grant the user the "wazuh" role (read-only is sufficient for polling).
WAZUH_USER=wazuh-api
WAZUH_PASS=change-me-strong-password

# Set to true only if your Wazuh installation uses a properly CA-signed TLS certificate.
# Wazuh ships with a self-signed cert by default, so this should stay false unless
# you have replaced it with a trusted certificate.
WAZUH_VERIFY_TLS=false

# Wazuh Indexer (OpenSearch) — used by wazuh_fetch_alerts for real security alerts
# Defaults to the same host as the Wazuh Manager. User/pass are the OpenSearch admin credentials
# (same ones used to log into the Wazuh Dashboard).
WAZUH_INDEXER_URL=https://host.docker.internal:9200
WAZUH_INDEXER_USER=admin
WAZUH_INDEXER_PASS=your-dashboard-password
